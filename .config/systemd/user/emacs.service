[Unit]
Description=Emacs: the extensible, self-documenting text editor
Requires=foot-server.service
After=foot-server.service

[Service]
Type=forking
EnvironmentFile=-%h/.config/environment.d/keys.conf
ExecStart=/usr/bin/emacs --daemon
ExecStop=/usr/bin/emacsclient --eval "(progn (setq kill-emacs-hook '(server-force-stop))(recentf-save-list)(kill-emacs))"
Restart=on-failure

[Install]
WantedBy=graphical-session.target
